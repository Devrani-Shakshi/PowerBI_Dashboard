<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DummyDataSource">
      <ConnectionProperties>
        <DataProvider>SQLAZURE</DataProvider>
        <ConnectString>Data Source=(local);Initial Catalog=Dummy;</ConnectString>
      </ConnectionProperties>
    </DataSource>
  </DataSources>
  <ReportParameters>
    <ReportParameter Name="DynamicFilter1">
      <DataType>String</DataType>
      <Prompt>Company</Prompt>
      <AllowBlank>true</AllowBlank>
      <Nullable>true</Nullable>
    </ReportParameter>
    <ReportParameter Name="DynamicFilter2">
      <DataType>String</DataType>
      <Prompt>Description</Prompt>
      <AllowBlank>true</AllowBlank>
      <Nullable>true</Nullable>
    </ReportParameter>
    <ReportParameter Name="DynamicFilter3">
      <DataType>String</DataType>
      <Prompt>Region</Prompt>
      <AllowBlank>true</AllowBlank>
      <Nullable>true</Nullable>
    </ReportParameter>
    <ReportParameter Name="TenantId">
      <DataType>String</DataType>
      <Nullable>true</Nullable>
      <Prompt>TenantId</Prompt>
      <Hidden>true</Hidden>
    </ReportParameter>
  </ReportParameters>
  <DataSets>
    <DataSet Name="InvoiceDataSet">
      <Query>
        <DataSourceName>DummyDataSource</DataSourceName>
        <CommandText>
SELECT *
FROM
(
    SELECT 
        1 AS InvoiceId,
        'ABC Ltd' AS Company,
        'Laptop Purchase' AS Description,
        'North' AS Region

    UNION ALL

    SELECT 
        2,
        'XYZ Corp',
        'Office Chairs',
        'South'

    UNION ALL

    SELECT 
        3,
        'ABC Ltd',
        'Printer',
        'East'
) AS InvoiceData

WHERE TenantId = @TenantId AND 
(@DynamicFilter1 IS NULL OR Company = @DynamicFilter1)
AND
(@DynamicFilter2 IS NULL OR Description = @DynamicFilter2)
AND
(@DynamicFilter3 IS NULL OR Region = @DynamicFilter3)
        </CommandText>
        <QueryParameters>
          <QueryParameter Name="@DynamicFilter1">
            <Value>=Parameters!DynamicFilter1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DynamicFilter2">
            <Value>=Parameters!DynamicFilter2.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DynamicFilter3">
            <Value>=Parameters!DynamicFilter3.Value</Value>
          </QueryParameter>
        </QueryParameters>
      </Query>
      <Fields>
        <Field Name="InvoiceId">
          <DataField>InvoiceId</DataField>
        </Field>
        <Field Name="Company">
          <DataField>Company</DataField>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
        </Field>
        <Field Name="Region">
          <DataField>Region</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <Body>
    <ReportItems>
      <Textbox Name="Textbox1">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>Invoice Test Report</Value>
                <Style>
                  <FontSize>16pt</FontSize>
                  <FontWeight>Bold</FontWeight>
                </Style>
              </TextRun>
            </TextRuns>
          </Paragraph>
        </Paragraphs>
        <Top>0.2in</Top>
        <Left>0.2in</Left>
        <Height>0.3in</Height>
        <Width>3in</Width>
        <Style />
      </Textbox>
    </ReportItems>
    <Height>2in</Height>
    <Style />
  </Body>
  <Width>6in</Width>
  <Page>
    <PageHeight>11in</PageHeight>
    <PageWidth>8.5in</PageWidth>
    <LeftMargin>1in</LeftMargin>
    <RightMargin>1in</RightMargin>
    <TopMargin>1in</TopMargin>
    <BottomMargin>1in</BottomMargin>
    <Style />
  </Page>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <rd:ReportID>11111111-1111-1111-1111-111111111111</rd:ReportID>
</Report>