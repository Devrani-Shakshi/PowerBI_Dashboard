  <DataSets>
    <DataSet Name="PrimaryDataSet">
      <Query>
        <DataSourceName>QueryDataSource</DataSourceName>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
        <CommandText>Select	tblAction.ReferenceID, 
		tblAction.ActionID, 
		tblAction.ActionDescription, 
		tblAsset.AssetDescription, 
		tblAction.PO, 
		tblAction.Account,
		tblAction.UserText17, 
		tblCategory.CategoryDescription, 
		tblLocation.Location, 
		tblSubAction.ActionID AS SubActionID, 
		tblSubAction.ActionDescription AS SubActionDescription,
		tblSubAction.UserText6 AS PreviousReference, 
		tblSubasset.AssetDescription AS SubAssetDescription, 
		tblSubAction.Location AS SubActionLocation, 
		tblSubAction.ReferenceID AS SubActionReferenceID, 
tblSubAction.UserNumber16, 
		tblSubAction.FinishDate, 
		tblSubAction.StartDate,
		tblSubAction.Account AS SubAccount1,
		tblActionTask.TaskID, 
		([tblActionAssignment].[EstRate]*[tblActionAssignment].[estquantity]) AS Estimate, 
		tblContractor.Contractor, tblSubAction.ContractNumber
From	tblAction INNER JOIN 
		tblAction AS tblSubAction ON tblAction.ActionID = tblSubAction.ParentID LEFT JOIN
tblActionTask ON tblSubAction.ActionID = tblActionTask.ActionID LEFT JOIN 
		tblActionAssignment ON tblActionTask.TaskID = tblActionAssignment.TaskID LEFT JOIN  
		tblAsset AS tblSubasset ON tblSubAction.AssetID = tblSubasset.AssetID LEFT JOIN 
		tblContractor ON tblSubAction.ContractID = tblContractor.contractID LEFT JOIN 
		tblCategory ON tblAction.ActionCategory = tblCategory.CategoryID LEFT JOIN 
		tblLocation ON tblAction.LocationID = tblLocation.LocationID INNER JOIN 
		tblAsset ON tblAction.AssetID = tblAsset.AssetID
		
Where
 (tblAction.ActionID = 38) AND 
	tblaction.ActionID &gt;=1</CommandText>
      </Query>
