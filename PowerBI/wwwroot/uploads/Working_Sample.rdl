'#start section-------[DO NOT CHANGE]Generated by Conquest------------#
Dim inputKey As String = "m91io0Ci07"
Dim urlBase as string = "api-jagdish.conquest-solutions.com.au/ImageProxy/?r=eyJrIjoibTkxaW8wQ2kwNyIsInUiOiJrZXl1ci5zaGFoQGNvbnF1ZXN0c29mdHdhcmUuY29tLmF1IiwibSI6ImRqeEc3Y3AwTFN4d0ZCR3IrVWVYcUNjRjFYZz0iLCJkIjoiYmxvYjovL2RlZmF1bHQvIn0&amp;p="
Public Function ToImageUrl(input As String) As String
    Dim key = inputKey.ToCharArray()
    Dim xorOutput = New Char(input.Length - 1) {}
    For i As Integer = 0 To input.Length - 1
        Dim left As Integer = AscW(input(i))
        Dim right As Integer = AscW(key(i Mod key.Length))
        xorOutput(i) = ChrW(left Xor right)
    Next
    Dim xorResult = New String(xorOutput)
    Dim utf8 = New System.Text.UTF8Encoding()
    Dim base64 = Convert.ToBase64String(utf8.GetBytes(xorResult))
    Dim result = base64.TrimEnd("="c).Replace("+"c, "-"c).Replace("/"c, "_"c)
    Return urlBase + result
End Function
'#end section---------[DO NOT CHANGE]Generated by Conquest------------#</Code>
