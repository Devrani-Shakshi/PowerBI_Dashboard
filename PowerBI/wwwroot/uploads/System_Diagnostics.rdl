          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="WorkspaceId">
          <DataField>WorkspaceId</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
