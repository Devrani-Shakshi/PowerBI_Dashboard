<?xml version="1.0" encoding="utf-8"?>
<Report MustUnderstand="df" xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner" xmlns:df="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition/defaultfontfamily">
  <df:DefaultFontFamily>Segoe UI</df:DefaultFontFamily>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DummyDataSource">
      <ConnectionProperties>
        <DataProvider>SQLAZURE</DataProvider>
        <ConnectString>Data Source=dummy-server.database.windows.net;Initial Catalog=DummyDB</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>e1a2b3c4-d5e6-4f7g-8h9i-j0k1l2m3n4o5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="SalesData">
      <Query>
        <DataSourceName>DummyDataSource</DataSourceName>
        <CommandText>SELECT * FROM (SELECT 'New York' AS City, 'Electronics' AS Category, 1500 AS Sales, '2026-01-01' AS SaleDate
UNION ALL SELECT 'London', 'Furniture', 1200, '2026-01-02'
UNION ALL SELECT 'Tokyo', 'Electronics', 2000, '2026-01-03'
UNION ALL SELECT 'Paris', 'Clothing', 800, '2026-01-04'
UNION ALL SELECT 'Berlin', 'Furniture', 1100, '2026-01-05') AS [DummyData] WHERE TenantId = @TenantId</CommandText>
      </Query>
      <Fields>
        <Field Name="City">
          <DataField>City</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Category">
          <DataField>Category</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Sales">
          <DataField>Sales</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="SaleDate">
          <DataField>SaleDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
