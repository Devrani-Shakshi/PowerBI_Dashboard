<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="QueryDataSource">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Server=ZSDESKT8IBNL5\SQLEXPRESS;Database=powerBIdemo;Trusted_Connection=True;TrustServerCertificate=True;</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>6ca78684-c35e-4dd9-9420-3f82b3e06919</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="PrimaryDataSet">
      <Query>
        <DataSourceName>QueryDataSource</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ActionID">
            <Value>=Parameters!ActionID.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>Select	matcode.text AS UOM, 
		tblcode.text, 
		tblActionAssignment.estrate, 
		tblActionAssignment.AssignmentID,
		tblAction.EntryDate, 
		tblActRequest.ReceivedBy, 
		tblAsset.AssetID, 
		tblAsset.AssetDescription, 
		tblAsset.FamilyCode, 
		tblAction.ActionDescription, 
		tblAction.ReferenceID, 
		tblAction.account, 
		tblAction.CreatedBy AS createby, 
		PreAction.ActionNotes, 
		tblAction.ActionID, 
		tblResource.UserCode1, 
		tblActionTask.TaskID, 
		tblResource.Name AS ResourceDescription, 
		tblActionAssignment.Units, 
		tblActionAssignment.EstQuantity, 
		tblAction.IssueDate, 
		tblObs.OBSName AS inspby, 
		CurOBS.OBSName AS dept, 
		PreAction.CmpDate, 
		tblActRequest.Request, 
		tblActRequest.LastName, 
		tblActRequest.FirstName, 
		tblActRequest.HomePhone, 
		tblaction.Location, 
		tblCode.Text AS priority, 
		tblActionTask.TaskName, 
		tblAction.ActionNotes AS CurrentNotes, 
			CASE WHEN Len(tblAction.Account) &gt; 3 THEN tblAction.Account ELSE tblAction.Usertext1 END AS JobNo,
			CASE WHEN Len(tblactrequest.docref) &gt; 1 THEN tblActRequest.DocRef ELSE tbldocref.Maxofdocref END AS docref 
			
From	tblAction LEFT JOIN 
		tblAction AS PreAction ON tblaction.PreviousAction = PreAction.ActionID LEFT JOIN 
		tblReqActXRef ON PreAction.ActionID = tblReqActXRef.ActionID LEFT JOIN 
		tblActRequest ON tblReqActXRef.ArqID = tblActRequest.ArqID LEFT JOIN 
		tblObs ON PreAction.Department = tblObs.OrgID LEFT JOIN 
		tblAsset ON PreAction.AssetID = tblAsset.AssetID LEFT JOIN 
		tblCode ON tblAction.UserList1 = tblCode.CodeID LEFT JOIN 
		tblActionTask ON tblaction.ActionID = tblActionTask.ActionID LEFT JOIN 
		tblActionAssignment ON tblActionTask.TaskID = tblActionAssignment.TaskID LEFT JOIN 
		tblcode AS matcode ON tblActionAssignment.materialunits = matcode.codeid LEFT JOIN 
		tblResource ON tblActionAssignment.ResourceID = tblResource.ResourceID LEFT JOIN 
		tblOBS AS CurOBS ON tblaction.department = CurOBS.orgid LEFT JOIN 
			(SELECT tblAction.ActionID, Max(tblActRequest.DocRef) AS MaxOfDocRef
			FROM	(tblAction LEFT JOIN 
					tblReqActXRef ON tblAction.ActionID = tblReqActXRef.ActionID) LEFT JOIN 
					tblActRequest ON tblReqActXRef.ArqID = tblActRequest.ArqID
			GROUP BY tblAction.ActionID)
		AS tbldocref ON tblaction.actionid = tbldocref.actionid 

Where	tblAction.ActionID = @ActionID -- for some reason, the original filter was set to include all</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
