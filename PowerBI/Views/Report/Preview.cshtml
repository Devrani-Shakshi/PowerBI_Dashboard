@model PowerBI.Models.ReportEmbedConfig

@{
    ViewData["Title"] = "Report Preview";
}

<style>
    .filter-sidebar {
        width: 300px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(10px);
        border-left: 1px solid rgba(0, 0, 0, 0.05);
        height: 850px;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

    .filter-header {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        background: #fff;
    }

    .filter-scroll-area {
        flex: 1;
        overflow-y: auto;
        padding: 1rem;
    }

    .filter-group {
        margin-bottom: 1.5rem;
        background: #fff;
        border-radius: 12px;
        border: 1px solid rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .filter-group-header {
        padding: 0.75rem 1rem;
        background: #f8f9fa;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .filter-group-content {
        padding: 0.75rem;
        max-height: 250px;
        overflow-y: auto;
    }

    .filter-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 0.4rem 0.5rem;
        border-radius: 6px;
        transition: background 0.2s;
        cursor: pointer;
    }

    .filter-item:hover {
        background: #f1f3f5;
    }

    .filter-item input {
        width: 16px;
        height: 16px;
        cursor: pointer;
    }

    .filter-item label {
        font-size: 0.85rem;
        margin: 0;
        cursor: pointer;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .search-input {
        background: #f1f3f5;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1rem;
        font-size: 0.85rem;
        width: 100%;
        margin-top: 0.5rem;
    }

    .filter-badge {
        background: #0d6efd;
        color: white;
        border-radius: 50%;
        width: 18px;
        height: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
    }
</style>

<div class="row mb-4">
    <div class="col">
        <h2 class="fw-bold m-0">@Model.ReportName</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Workspace" asp-action="Index">Workspaces</a></li>
                <li class="breadcrumb-item active">Preview</li>
            </ol>
        </nav>
    </div>
    <div class="col-auto d-flex gap-2 align-items-center">
        <button onclick="exportToPdf()" id="exportBtn" class="btn btn-primary shadow-sm px-4">
            <i class="bi bi-file-earmark-pdf me-2"></i>Export PDF
        </button>
        <button onclick="reloadReport()" class="btn btn-outline-secondary px-3">
            <i class="bi bi-arrow-clockwise"></i>
        </button>
    </div>
</div>

<div class="row g-0 shadow-lg overflow-hidden" style="border-radius: 1.5rem; background: #fff;">
    <!-- Main Report Area -->
    <div class="col">
        <div id="reportContainer" style="height: 850px; width: 100%;"></div>
    </div>

    <!-- Professional Filter Sidebar -->
    <div class="filter-sidebar" id="filterSidebar">
        <div class="filter-header">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <h6 class="fw-bold m-0"><i class="bi bi-funnel me-2"></i>Filters</h6>
                <div class="d-flex gap-2">
                    @if (Model.ReportType == "RDL")
                    {
                        <button data-bs-toggle="modal" data-bs-target="#manualFilterModal" class="btn btn-link btn-sm p-0 text-decoration-none text-primary" title="Add Filter Manually">
                            <i class="bi bi-plus-circle"></i>
                        </button>
                        <button onclick="discoverRdlParameters()" id="rdlSyncBtn" class="btn btn-link btn-sm p-0 text-decoration-none text-primary" title="Sync Parameters">
                            <i class="bi bi-arrow-repeat"></i>
                        </button>
                    }
                    <button onclick="clearAllFilters()" class="btn btn-link btn-sm p-0 text-decoration-none">Clear all</button>
                </div>
            </div>
            <input type="text" class="search-input" placeholder="Search filters..." onkeyup="searchFilters(this.value)">
        </div>
        
        <div class="filter-scroll-area" id="filterArea">
            <div class="text-center py-5" id="filterLoader">
                <div class="spinner-border text-primary spinner-border-sm" role="status"></div>
                <p class="text-muted small mt-2">Discovering filters...</p>
            </div>
        </div>
    </div>
</div>

<!-- Export Progress Overlay -->
<div id="actionOverlay" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(255,255,255,0.9); z-index:9999; flex-direction:column; align-items:center; justify-content:center;">
    <div class="text-center">
        <div class="spinner-border text-primary mb-3" style="width: 3rem; height: 3rem;" role="status"></div>
        <h4 class="fw-bold text-dark" id="actionStatus">Processing...</h4>
        <p class="text-muted">Please wait while we prepare your file.</p>
    </div>
</div>

<!-- Add Manual Filter Modal -->
<div class="modal fade" id="manualFilterModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 1rem;">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold">Metadata & Filters</h6>
                <span class="badge bg-light text-dark extra-small border">User ID: @Context.Session.GetInt32("UserId")</span>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-4">Enter the field details to add a new filter to the report.</p>
                <div class="mb-3">
                    <label class="form-label text-muted small">Display Name</label>
                    <input type="text" id="manual_display_name" class="form-control bg-light border-0" placeholder="e.g. Invoice Number">
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small">Category/Table (Label)</label>
                    <input type="text" id="manual_table_name" class="form-control bg-light border-0" placeholder="e.g. Sales">
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small">Field/Column Name (XML Name)</label>
                    <input type="text" id="manual_column_name" class="form-control bg-light border-0" placeholder="e.g. InvoiceId">
                    <div class="form-text extra-small mt-1 text-primary">Note: For RDL, this will be permanently injected into the XML file.</div>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
                <button type="button" onclick="saveManualFilter()" class="btn btn-primary rounded-pill px-4" id="saveFilterBtn">Add & Apply</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const reportType = '@Model.ReportType' === 'PaginatedReport' ? 'RDL' : '@Model.ReportType';
        const datasetId = (reportType === 'RDL') ? null : '@Model.DatasetId';
        const localReportId = '@Model.LocalReportId';
        const pbiWorkspaceId = '@Model.WorkspaceId';
        const pbiReportId = '@Model.ReportId';
        let activeFilters = {}; // Key: "Table/Column", Value: [values]
        let availableFilters = [];

        // Fix for :tabbable error in Power BI RDL SDK conflicts
        if ($.expr && $.expr[':']) {
            $.expr[':'].tabbable = function(el) {
                var nodeName = el.nodeName.toLowerCase();
                var isTabIndexNotNaN = !isNaN($.attr(el, 'tabindex'));
                return (/^(input|select|textarea|button|object)$/.test(nodeName) ?
                    !el.disabled :
                    'a' === nodeName ?
                        el.href || isTabIndexNotNaN :
                        isTabIndexNotNaN
                ) && $(el).is(':visible');
            };
        }

        let report;
        let secureUrl = '';
        let config;

        $(document).ready(function () {
            const container = $('#reportContainer')[0];
            const baseEmbedUrl = '@Html.Raw(Model.EmbedUrl)';
            
            if (!baseEmbedUrl || baseEmbedUrl === 'undefined' || baseEmbedUrl === '') {
                console.error("[CRITICAL] Cannot initialize frame. Model.EmbedUrl is empty or undefined.");
                $('#reportContainer').html('<div class="alert alert-danger">Configuration Error: Secure Embed URL is missing.</div>');
                return;
            }

            // Force /rdlEmbed to bypass standard report telemetry
            secureUrl = baseEmbedUrl.replace('/reportEmbed', '/rdlEmbed');
            const reportTypeLocal = '@Model.ReportType';
            

            config = {
                type: 'report', 
                id: '@Model.ReportId',
                embedUrl: secureUrl,
                accessToken: '@Model.EmbedToken',
                tokenType: 1, // models.TokenType.Embed
                settings: {
                    commands: {
                        parameterPanel: { enabled: false }
                    }
                }
            };

            console.log("[PREVIEW] Final Embed Config:", {
                reportId: config.id,
                tokenType: config.tokenType,
                url: config.embedUrl
            });

            console.log("[PREVIEW] Resetting container...");
            
            console.log("[PREVIEW] Document Ready. Resetting container...");
            // RESET: Wipe any cached session state from the DOM wrapper
            powerbi.reset(container);
            
            console.log("[PREVIEW] Calling powerbi.embed()...");
            report = powerbi.embed(container, config);

            // DIAGNOSTICS: Catch RDL specific rendering errors
            report.on('error', function (event) {
                console.error("[POWERBI-SDK-ERROR]", event.detail);
                if (event.detail.message && event.detail.message.includes("403")) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Access Denied',
                        text: 'The report dataset requires a Premium capacity or Gateway binding.',
                        confirmButtonColor: '#0d6efd'
                    });
                }
            });

            // Load filters immediately so they appear even if the report is slow to load
            loadFilters();

            report.on("loaded", async () => {
                console.log("[PREVIEW] Report Event: LOADED");
            });

            report.on("rendered", function () {
                console.log("[PREVIEW] Report Event: RENDERED");
                Toast.fire({ icon: 'success', title: 'Report rendered successfully' });
            });

            report.on("error", function (event) {
                console.error("[PREVIEW] Report Event: ERROR", event.detail);
                if (event.detail.message && event.detail.message.includes("403")) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Access Denied',
                        text: 'The report dataset requires a Premium capacity or Gateway binding.',
                        confirmButtonColor: '#0d6efd'
                    });
                }
            });
        });

        async function loadFilters() {
            const filterArea = $('#filterArea');
            // Clear current filters to avoid "redundant" skips during sync
            filterArea.empty();
            activeFilters = {}; 

            try {
                let url = `/Report/GetFilters?reportId=${localReportId}`;
                const response = await fetch(url);
                const filters = await response.json();
                
                availableFilters = filters; // Store globally for RDL param handling
                console.log("[PREVIEW] Loaded filters:", filters);

                if (!filters || filters.length === 0) {
                    if (reportType === 'RDL') {
                        filterArea.html(`
                            <div class="alert alert-info p-3 m-2 small shadow-sm" style="border-radius: 10px; background: rgba(13, 110, 253, 0.05); border: 1px solid rgba(13, 110, 253, 0.1);">
                                <h6 class="fw-bold mb-1 text-primary"><i class="bi bi-cpu-fill me-2"></i>Parameter Sync</h6>
                                <p class="mb-2 text-dark" style="font-size: 0.8rem;">No parameters discovered for this RDL report.</p>
                                <button onclick="discoverRdlParameters()" id="scanBtn" class="btn btn-sm btn-primary w-100 fw-bold">
                                    <i class="bi bi-arrow-repeat me-2"></i>Sync Parameters
                                </button>
                            </div>
                        `);
                        // Auto-trigger for RDL if empty
                        console.log("[PREVIEW] Auto-triggering RDL parameter discovery...");
                        setTimeout(() => discoverRdlParameters(), 500);
                    } else {
                        filterArea.html(`
                            <div class="alert alert-info p-3 m-2 small shadow-sm" style="border-radius: 10px; background: rgba(13, 110, 253, 0.05); border: 1px solid rgba(13, 110, 253, 0.1);">
                                <h6 class="fw-bold mb-1 text-primary"><i class="bi bi-cpu-fill me-2"></i>Smart Discovery</h6>
                                <p class="mb-2 text-dark" style="font-size: 0.8rem;">No filters found for this user.</p>
                                <button onclick="runSmartScan()" id="scanBtn" class="btn btn-sm btn-primary w-100 fw-bold">
                                    <i class="bi bi-search me-2"></i>Scan Report
                                </button>
                            </div>
                        `);
                    }
                    return;
                }

                // Group by Custom vs System
                const systemFilters = filters.filter(f => !f.isCustom);
                const customFilters = filters.filter(f => f.isCustom);

                if (systemFilters.length > 0) {
                    filterArea.append('<div class="px-3 py-1 bg-light text-uppercase fw-bold text-muted border-bottom mb-2" style="font-size: 0.65rem; letter-spacing: 0.05rem;">Report Parameters</div>');
                    systemFilters.forEach(f => addFilterGroup(f));
                }

                if (customFilters.length > 0) {
                    filterArea.append('<div class="px-3 py-1 bg-light text-uppercase fw-bold text-muted border-bottom mt-3 mb-2" style="font-size: 0.65rem; letter-spacing: 0.05rem;">My Custom Filters</div>');
                    customFilters.forEach(f => addFilterGroup(f));
                }

                // AUTO-APPLY for RDL on first load to satisfy engine dependencies
                if (reportType === 'RDL' && !window.initialRdlApplied) {
                    console.log("[PREVIEW] Initial RDL Parameter Injection...");
                    window.initialRdlApplied = true;
                    setTimeout(() => applySidebarFilters(), 500);
                }
            } catch (error) {
                console.error("[PREVIEW] Load Filters Error:", error);
                filterArea.html('<div class="p-3 text-danger small">Error loading filters.</div>');
            }
        }

        function addFilterGroup(field) {
            // Handle both camelCase and PascalCase from API
            const table = field.tableName || field.TableName || field.table;
            const column = field.columnName || field.ColumnName || field.column;
            const id = field.id || field.Id;

            if (column === 'TenantId') return;

            // --- PREVENT DUPLICATION ---
            const isDuplicate = $(`[data-column="${column}"]`).length > 0;
            if (isDuplicate && table !== 'RDL_PARAMETER') {
                console.log(`[PREVIEW] Skipping redundant filter UI for: ${column}`);
                return;
            }

            console.log(`[PREVIEW] Adding filter group: ${table}.${column}`);

            const group = $(`
                <div class="filter-group mb-2 border rounded shadow-sm bg-white" data-table="${table}" data-column="${column}">
                    <div class="filter-group-header p-2 d-flex justify-content-between align-items-center cursor-pointer bg-light">
                        <span class="fw-bold small text-dark" onclick="$(this).parent().next().slideToggle()">${column}</span>
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-trash text-danger cursor-pointer extra-small" onclick="deleteFilter(${id}, this)" title="Remove Filter"></i>
                            <i class="bi bi-chevron-down small" onclick="$(this).parent().parent().next().slideToggle()"></i>
                        </div>
                    </div>
                    <div class="filter-group-content p-2" style="display:none; max-height: 200px; overflow-y: auto;">
                        <div class="text-center p-2"><div class="spinner-border spinner-border-sm text-secondary"></div></div>
                    </div>
                </div>
            `);

            $('#filterArea').append(group);
            
            // Lazy load values
            loadColumnValues(table, column, group.find('.filter-group-content'));
        }

        async function loadColumnValues(table, column, container) {
            try {
                // ENTERPRISE: Use internal localReportId. Backend will resolve the active runtime session ID.
                let url = `/Report/GetFilterValues?localReportId=${localReportId}&table=${encodeURIComponent(table)}&column=${encodeURIComponent(column)}&datasetId=${datasetId}`;
                const response = await fetch(url);
                const values = await response.json();
                
                container.empty();
                if (values.length === 0) throw new Error("No values");

                values.forEach(val => {
                    const item = $(`
                        <div class="filter-item">
                            <input type="checkbox" id="chk_${table}_${column}_${val}" onchange="toggleFilter('${table}', '${column}', '${val}', this.checked)">
                            <label for="chk_${table}_${column}_${val}">${val}</label>
                        </div>
                    `);
                    container.append(item);
                });
            } catch (err) {
                // FALLBACK: Manual Value Input
                container.empty().append(`
                    <div class="p-2">
                        <p class="text-muted small mb-2"><i class="bi bi-info-circle me-1"></i>Type value to filter:</p>
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control" placeholder="e.g. June" id="manual_val_${table}_${column}">
                            <button class="btn btn-primary" onclick="applySidebarFilters()">Apply</button>
                        </div>
                    </div>
                `);
            }
        }

        async function applyManualValue(table, column) {
            const val = $(`#manual_val_${table}_${column}`).val();
            if (!val) return;
            
            const key = `${table}/${column}`;
            activeFilters[key] = [val]; // For manual entry, we treat it as a single-select override
            
            await applyAllFilters();
        }

        async function toggleFilter(table, column, value, isChecked) {
            const key = `${table}/${column}`;
            if (!activeFilters[key]) activeFilters[key] = [];

            if (isChecked) {
                activeFilters[key].push(value);
            } else {
                activeFilters[key] = activeFilters[key].filter(v => v !== value);
            }

            await applySidebarFilters();
        }

        async function applySidebarFilters() {
            console.log("[PREVIEW] applySidebarFilters triggered for Type:", reportType);
            
            if (reportType === 'RDL') {
                const rdlParameters = [];
                
                // 1. Collect from checkbox state
                for (const key in activeFilters) {
                    const [table, col] = key.split('/');
                    const values = activeFilters[key];
                    if (values && values.length > 0 && values[0] !== "" && values[0] !== "ALL") {
                        rdlParameters.push({ name: col, value: values[0] });
                    }
                }

                // 2. Collect from manual input fields
                availableFilters.forEach(f => {
                    const col = f.columnName || f.column;
                    const manualVal = $(`#manual_val_${f.tableName}_${col}`).val();
                    if (manualVal && manualVal !== "" && manualVal !== "ALL" && !rdlParameters.find(p => p.name === col)) {
                        rdlParameters.push({ name: col, value: manualVal });
                    }
                });

                try {
                    const urlObj = new URL(secureUrl);
                    const params = new URLSearchParams(urlObj.search);
                    
                    // Clear existing rp: parameters to prevent bloating
                    const keysToDelete = [];
                    params.forEach((v, k) => { if (k.startsWith('rp:')) keysToDelete.push(k); });
                    keysToDelete.forEach(k => params.delete(k));

                    // Inject new rp: parameters
                    rdlParameters.forEach(p => {
                        console.log(`[RDL-FILTER] Injecting: rp:${p.name} = ${p.value}`);
                        params.set(`rp:${p.name}`, p.value);
                    });

                    params.set('rdl:parameterPanel', 'collapsed');
                    // CRITICAL: Power BI RDL parameters require literal colons, not encoded %3A
                    urlObj.search = params.toString().replace(/%3A/g, ':');

                    const rdlConfig = { 
                        ...config, 
                        embedUrl: urlObj.toString()
                    };
                    
                    // Ensure NO datasetId in RDL config
                    delete rdlConfig.datasetId;

                    console.log("[RDL-FILTER] Final RDL URL:", rdlConfig.embedUrl);

                    powerbi.reset($('#reportContainer')[0]);
                    report = powerbi.embed($('#reportContainer')[0], rdlConfig);
                    
                    Toast.fire({ icon: 'success', title: `Applied ${rdlParameters.length} active parameter(s)` });
                } catch (e) {
                    console.error("[RDL-FILTER] Error:", e);
                }
                return;
            }

            // Fallback for PBIX reports (Standard Apply)
            await applyAllFilters();
        }

        async function applyAllFilters() {
            // Power BI (PBIX) Filter Logic
            const pbiFilters = [];
            for (const key in activeFilters) {
                const [table, column] = key.split('/');
                const values = activeFilters[key];
                if (values.length > 0) {
                    pbiFilters.push({
                        $schema: "http://powerbi.com/product/schema#basic",
                        target: { table: table, column: column },
                        operator: "In",
                        values: values
                    });
                }
            }
            try {
                await report.setFilters(pbiFilters);
                Toast.fire({ icon: 'success', title: 'Filter applied successfully!' });
            } catch (err) {
                console.error("[PREVIEW] PBI Filter Error:", err);
            }
        }

        async function clearAllFilters() {
            console.log("[PREVIEW] Clearing all filters...");
            $('input[type="checkbox"]').prop('checked', false);
            $('input[type="text"]').val(''); // Clear manual inputs
            activeFilters = {};
            
            if (reportType === 'RDL' || reportType === 'PaginatedReport') {
                // For RDL, we must reload the original URL to clear parameters
                console.log("[SINGLE-REPORT] Resetting RDL view...");
                
                const urlObj = new URL(embedUrl);
                const params = new URLSearchParams(urlObj.search);
                params.set('rdl:parameterPanel', 'collapsed'); // Keep panel closed
                
                // Ensure base parameters are cleared in the URL
                urlObj.search = params.toString();
                
                const resetConfig = {
                    ...config,
                    embedUrl: urlObj.toString()
                };

                powerbi.reset($('#reportContainer')[0]);
                report = powerbi.embed($('#reportContainer')[0], resetConfig);
            } else {
                // For standard PBIX
                await report.removeFilters();
            }
            
            Toast.fire({ icon: 'info', title: 'Filters cleared.' });
        }

        function searchFilters(query) {
            const q = query.toLowerCase();
            $('.filter-group').each(function() {
                const text = $(this).find('.filter-group-header span').text().toLowerCase();
                $(this).toggle(text.includes(q));
            });
        }

        async function exportToPdf() {
            const exportBtn = $('#exportBtn');
            const overlay = $('#actionOverlay');
            const originalHtml = exportBtn.html();
            
            $('#actionStatus').text("Exporting to PDF...");
            exportBtn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Exporting...');
            overlay.css('display', 'flex').hide().fadeIn();

            try {
                // Convert active filters to the format expected by the backend export
                const exportFilters = [];
                for (const key in activeFilters) {
                    const [table, column] = key.split('/');
                    const values = activeFilters[key];
                    if (values.length > 0) {
                        // Support multi-select in OData filter string for export
                        const filterString = values.map(v => `${table}/${column} eq '${v}'`).join(' or ');
                        exportFilters.push({
                            filter: filterString
                        });
                    }
                }

                const response = await fetch(`/Report/ExportWithFilters?reportId=@Model.LocalReportId`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(exportFilters)
                });

                if (response.ok) {
                    const blob = await response.blob();
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `@Model.ReportName` + ".pdf";
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                } else {
                    alert("Export failed.");
                }
            } catch (err) {
                alert("An error occurred during export.");
            } finally {
                exportBtn.prop('disabled', false).html(originalHtml);
                overlay.fadeOut();
            }
        }

        async function runSmartScan() {
            if (reportType === 'RDL') {
                console.log("[PREVIEW] RDL detected. Redirecting Smart Scan to Parameter Discovery.");
                await discoverRdlParameters();
                return;
            }

            const btn = $('#scanBtn');
            const original = btn.html();
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Scanning...');

            try {
                const pages = await report.getPages();
                const fieldsFound = new Set();

                for (const page of pages) {
                    const visuals = await page.getVisuals();
                    for (const visual of visuals) {
                        // Discover from existing filters on visuals or from underlying data targets
                        const vFilters = await visual.getFilters();
                        vFilters.forEach(f => {
                            if (f.target && f.target.table && f.target.column) {
                                fieldsFound.add(`${f.target.table}|${f.target.column}`);
                            }
                        });
                    }
                }

                if (fieldsFound.size === 0) {
                    alert("No active fields discovered. Please interact with the report visuals first, or click 'Add manually' to type a field name.");
                } else {
                    const fields = Array.from(fieldsFound).map(fk => {
                        const [table, column] = fk.split('|');
                        return { TableName: table, ColumnName: column, DisplayName: column };
                    });

                    const response = await fetch('/Report/SaveBulkFilters', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            ReportId: parseInt(localReportId),
                            Filters: fields
                        })
                    });

                    if (response.ok) {
                        alert(`Success! Discovered and saved ${fields.length} field(s).`);
                        await loadFilters();
                    } else {
                        throw new Error("Failed to save discovered fields.");
                    }
                }
            } catch (err) {
                console.error("Scan error:", err);
                alert("Smart Scan failed. Please add fields manually.");
            } finally {
                btn.prop('disabled', false).html(original);
            }
        }


        async function saveManualFilter() {
            const displayName = $('#manual_display_name').val();
            const tableName = $('#manual_table_name').val();
            const columnName = $('#manual_column_name').val();

            if (!displayName || !columnName) {
                Toast.fire({ icon: 'warning', title: 'Please fill Display and Column names.' });
                return;
            }

            const btn = $('#saveFilterBtn');
            const original = btn.html();
            btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Validating...');

            try {
                const response = await fetch('/Report/SaveCustomFilter', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        reportId: parseInt(localReportId),
                        displayName: displayName,
                        tableName: tableName,
                        columnName: columnName
                    })
                });

                const data = await response.json();

                if (response.ok) {
                    Toast.fire({ icon: 'success', title: 'Filter added successfully!' });
                    bootstrap.Modal.getInstance(document.getElementById('manualFilterModal')).hide();
                    
                    // --- ID DRIFT FIX ---
                    // If the report ID changed (common for RDL after injection), we MUST reload the page
                    // to re-initialize the Power BI embed with the new valid ID.
                    if (data.reportId && data.reportId !== pbiReportId) {
                        console.log("[SINGLE-REPORT] ID drift detected after filter injection. Reloading...");
                        setTimeout(() => window.location.reload(), 1000);
                        return;
                    }

                    // Refresh the filter list and apply
                    await loadFilters();
                } else {
                    // This will show the "Field 'X' not found in RDL dataset" error
                    Swal.fire({
                        icon: 'error',
                        title: 'Validation Failed',
                        text: data.message || "Failed to save filter.",
                        confirmButtonColor: '#0d6efd'
                    });
                }
            } catch (err) {
                console.error("Save error:", err);
                Toast.fire({ icon: 'error', title: 'An error occurred while saving.' });
            } finally {
                btn.prop('disabled', false).html(original);
            }
        }

        async function promptManualFilter() {
            // Deprecated - replaced by modal
            $('#manualFilterModal').modal('show');
        }

        function reloadReport() {
            if (report) report.reload();
        }

        async function discoverRdlParameters() {
            const btn = $('#rdlSyncBtn');
            btn.addClass('fa-spin').prop('disabled', true);
            
            try {
                const response = await fetch(`/Report/ResetFilters?reportId=${localReportId}`, { method: 'POST' });
                if (response.ok) {
                    const data = await response.json();
                    console.log("[SINGLE-REPORT] Sync result:", data);
                    
                    Toast.fire({ icon: 'success', title: 'Parameters synchronized.' });
                    
                    if (data.reportId && data.reportId !== pbiReportId) {
                        console.log("[SINGLE-REPORT] Report ID changed. Reloading for fresh embed...");
                        setTimeout(() => window.location.reload(), 1500);
                        return;
                    }

                    const filterArea = $('#filterArea');
                    filterArea.empty();
                    
                    if (data.filters && data.filters.length > 0) {
                        availableFilters = data.filters;
                        
                        // Group and render
                        const systemFilters = data.filters.filter(f => !f.isCustom);
                        const customFilters = data.filters.filter(f => f.isCustom);

                        if (systemFilters.length > 0) {
                            filterArea.append('<div class="px-3 py-1 bg-light text-uppercase fw-bold text-muted border-bottom mb-2" style="font-size: 0.65rem; letter-spacing: 0.05rem;">Report Parameters</div>');
                            systemFilters.forEach(f => addFilterGroup(f));
                        }

                        if (customFilters.length > 0) {
                            filterArea.append('<div class="px-3 py-1 bg-light text-uppercase fw-bold text-muted border-bottom mt-3 mb-2" style="font-size: 0.65rem; letter-spacing: 0.05rem;">My Custom Filters</div>');
                            customFilters.forEach(f => addFilterGroup(f));
                        }
                    } else {
                        filterArea.html('<div class="p-3 text-muted small text-center">No parameters found.</div>');
                    }
                } else {
                    Toast.fire({ icon: 'error', title: 'Sync failed. Check RDL file.' });
                }
            } finally {
                btn.removeClass('fa-spin').prop('disabled', false);
            }
        }

        async function deleteFilter(id, el) {
            if (!confirm("Remove this filter from your view?")) return;
            
            try {
                const response = await fetch(`/Report/DeleteFilter?filterId=${id}`, { method: 'POST' });
                if (response.ok) {
                    $(el).closest('.filter-group').fadeOut(function() { $(this).remove(); });
                } else {
                    alert("Failed to delete filter.");
                }
            } catch (err) {
                alert("Error deleting filter.");
            }
        }
    </script>
}

