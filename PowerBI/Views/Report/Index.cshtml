@model List<PowerBI.Models.Report>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold mb-1">Reports in @ViewBag.WorkspaceName</h2>
        <p class="text-muted small">
            <i class="bi bi-arrow-repeat text-primary animate-spin me-1"></i> 
            Synced with Power BI Service
        </p>
    </div>
    <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#uploadReportModal">
        <i class="bi bi-upload me-2"></i> Upload Report
    </button>
</div>

@if (ViewBag.SyncError != null)
{
    <div class="alert alert-warning glass-card border-0 mb-4">
        <i class="bi bi-cloud-slash me-2"></i> @ViewBag.SyncError
    </div>
}

<div class="d-flex flex-column animate-fade-in">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="breadcrumb" class="mb-3 px-2">
        <ol class="breadcrumb mb-0 py-2">
            <li class="breadcrumb-item"><a href="#" onclick="navigateToRoot()" class="text-decoration-none"><i class="bi bi-house-door me-1"></i> @ViewBag.WorkspaceName</a></li>
            <li class="breadcrumb-item active d-none" id="folderBreadcrumb"></li>
        </ol>
    </nav>

    <div class="glass-card border-0 overflow-hidden shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr class="text-muted small uppercase bg-light bg-opacity-50">
                        <th class="border-0 ps-4" style="width: 40%">Name</th>
                        <th class="border-0">Type</th>
                        <th class="border-0">Status</th>
                        <th class="border-0 text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody id="reportTableBody">
                    <!-- Folders -->
                    @foreach (var f in (List<PowerBI.Models.Folder>)ViewBag.Folders)
                    {
                        <tr class="folder-row cursor-pointer" onclick="navigateToFolder('@f.Id', '@f.Name')" data-folder-id="@f.Id">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-folder-fill text-warning fs-5 me-3"></i>
                                    <span class="fw-bold">@f.Name</span>
                                </div>
                            </td>
                            <td><span class="text-muted small">Folder</span></td>
                            <td><span class="text-muted extra-small">--</span></td>
                            <td class="text-end pe-4">
                                <i class="bi bi-chevron-right text-muted small"></i>
                            </td>
                        </tr>
                    }

                    <!-- Reports -->
                    @foreach (var r in Model)
                    {
                        <tr class="report-row" data-parent-folder="@(r.FolderId ?? 0)">
                            <td class="ps-4">
                                <div class="d-flex align-items-center">
                                    <div class="bg-primary bg-opacity-10 p-2 rounded me-3">
                                        <i class="bi bi-file-bar-graph text-primary"></i>
                                    </div>
                                    <span class="fw-bold">@r.Name</span>
                                </div>
                            </td>
                            <td>
                                <span class="text-muted small">@(r.ReportType == "RDL" ? "Paginated Report" : "Report")</span>
                            </td>
                            <td>
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2" style="font-size: 0.65rem;">Synced</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group">
                                    <a asp-action="Preview" asp-route-reportId="@r.Id" class="btn btn-sm btn-outline-primary rounded-pill px-3 me-1">View</a>
                                    <a asp-action="Export" asp-route-reportId="@r.Id" class="btn btn-sm btn-outline-secondary rounded-pill px-3 me-1">PDF</a>
                                    <form asp-action="Delete" asp-route-reportId="@r.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this report from Power BI?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    let currentFolderId = 0;

    function navigateToFolder(id, name) {
        currentFolderId = id;
        
        // Update Breadcrumb
        const bc = document.getElementById('folderBreadcrumb');
        bc.textContent = name;
        bc.classList.remove('d-none');
        
        filterTable();
    }

    function navigateToRoot() {
        currentFolderId = 0;
        
        // Update Breadcrumb
        document.getElementById('folderBreadcrumb').classList.add('d-none');
        
        filterTable();
    }

    function filterTable() {
        const rows = document.querySelectorAll('#reportTableBody tr');
        
        rows.forEach(row => {
            if (row.classList.contains('folder-row')) {
                // Folders are only visible at root
                row.style.display = (currentFolderId == 0) ? '' : 'none';
            } else if (row.classList.contains('report-row')) {
                // Reports are visible if they match the current folder ID
                const parentId = row.getAttribute('data-parent-folder');
                row.style.display = (parentId == currentFolderId) ? '' : 'none';
            }
        });
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', filterTable);
</script>

<style>
    .cursor-pointer { cursor: pointer; }
    .folder-row:hover { background-color: rgba(255, 193, 7, 0.05) !important; }
    .breadcrumb-item + .breadcrumb-item::before { content: ">"; }
    .extra-small { font-size: 0.75rem; }
</style>

<!-- Modal remains the same but with improved folder picker -->
<div class="modal fade" id="uploadReportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-card border-0">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold">Upload New Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" enctype="multipart/form-data" asp-action="Upload">
                <input type="hidden" name="workspaceId" value="@ViewBag.WorkspaceId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-muted small">Target Folder</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-light text-muted">
                                <i class="bi bi-folder-plus"></i>
                            </span>
                            <input type="text" name="folderName" id="folderInput" class="form-control bg-light border-light" 
                                   placeholder="e.g. Automated Reports, Q1-Sales, etc." 
                                   list="existingFolders" />
                            <datalist id="existingFolders">
                                @foreach (var f in (List<PowerBI.Models.Folder>)ViewBag.Folders)
                                {
                                    <option value="@f.Name">@f.Name</option>
                                }
                            </datalist>
                        </div>
                        <div class="form-text extra-small mt-1">Type a new name to create a folder, or select from existing.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Select .pbix or .rdl file</label>
                        <input type="file" name="file" class="form-control bg-light border-light" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted small">Target Filter Columns (RDL only)</label>
                        <input type="text" name="targetFields" class="form-control bg-light border-light" placeholder="e.g. InvoiceId, Company, Item" />
                        <div class="form-text extra-small mt-1">Comma-separated field names to automatically inject as filters.</div>
                    </div>
                    <div class="bg-light p-3 rounded-3 mb-3 border border-dashed">
                        <p class="small fw-bold mb-2">Samples:</p>
                        <div class="d-flex gap-2">
                            <a href="/Dummy_RDL.rdl" download class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-download me-1"></i> RDL
                            </a>
                            <a href="https://github.com/microsoft/powerbi-desktop-samples/raw/main/Monthly%20Sales%20and%20Profit%20Sample.pbix" target="_blank" class="btn btn-sm btn-outline-dark">
                                <i class="bi bi-file-earmark-bar-graph me-1"></i> PBIX
                            </a>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4">Start Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .animate-spin {
        animation: spin 2s linear infinite;
        display: inline-block;
    }
    @@keyframes spin {
        100% { transform: rotate(360deg); }
    }
    .uppercase { text-transform: uppercase; letter-spacing: 0.05em; }
    .extra-small { font-size: 0.7rem; }
</style>